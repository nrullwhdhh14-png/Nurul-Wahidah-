<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Manipulasi Elemen - Beban Pikiran</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, sans-serif;
    }

    body{
      height:100vh;
      overflow:hidden;
      background: linear-gradient(135deg, #ffb6e6, #9fd3ff);
      display:flex;
      flex-direction:column;
      align-items:center;
      position:relative;
    }

    h1{
      margin-top:25px;
      color:white;
      text-shadow:2px 2px 5px rgba(0,0,0,0.2);
      font-size:32px;
    }

    p{
      color:white;
      margin-top:10px;
      font-size:16px;
      text-align:center;
      width:80%;
    }

    .input-box{
      margin-top:20px;
      width:80%;
      max-width:500px;
      position:relative;
      z-index:10;
    }

    textarea{
      width:100%;
      height:120px;
      border:none;
      border-radius:20px;
      padding:15px;
      font-size:16px;
      resize:none;
      outline:none;
      background:rgba(255,255,255,0.9);
      box-shadow:0 5px 15px rgba(0,0,0,0.1);
    }

    .container{
      width:100%;
      height:100%;
      position:relative;
    }

    .box{
      width:180px;
      height:180px;
      background:linear-gradient(135deg, #ff7ecb, #6ec6ff);
      border-radius:30px;
      position:absolute;
      left:50%;
      top:250px;
      transform:translateX(-50%);
      display:flex;
      justify-content:center;
      align-items:center;
      flex-direction:column;
      transition:top 0.3s ease;
      box-shadow:0 15px 30px rgba(0,0,0,0.2);
    }

    .box h2{
      color:white;
      font-size:22px;
      margin-bottom:10px;
    }

    .emoji{
      font-size:60px;
    }

    /* Sticker lucu */
    .sticker{
      position:absolute;
      font-size:50px;
      opacity:0.9;
      animation:float 4s ease-in-out infinite;
    }

    .s1{
      top:100px;
      left:80px;
    }

    .s2{
      bottom:120px;
      right:100px;
      animation-delay:1s;
    }

    .s3{
      top:200px;
      right:120px;
      animation-delay:2s;
    }

    .s4{
      bottom:180px;
      left:100px;
      animation-delay:1.5s;
    }

    @keyframes float{
      0%{
        transform:translateY(0px);
      }
      50%{
        transform:translateY(-15px);
      }
      100%{
        transform:translateY(0px);
      }
    }

  </style>
</head>

<body>

  <h1>🧠 Beban Pikiran</h1>

  <p>
    Ketik beban pikiranmu di bawah ini.  
    Semakin panjang tulisanmu, kotak akan semakin turun karena keberatan.
  </p>

  <div class="input-box">
    <textarea id="textInput" placeholder="Tulis beban pikiranmu di sini..."></textarea>
  </div>

  <!-- Sticker -->
  <div class="sticker s1">☁️</div>
  <div class="sticker s2">💭</div>
  <div class="sticker s3">🩷</div>
  <div class="sticker s4">🌈</div>

  <div class="container">
    <div class="box" id="box">
      <h2>Beban</h2>
      <div class="emoji">😵‍💫</div>
    </div>
  </div>

  <script>
    const input = document.getElementById("textInput");
    const box = document.getElementById("box");

    input.addEventListener("input", () => {

      // panjang teks
      let length = input.value.length;

      // posisi awal
      let start = 250;

      // semakin panjang -> semakin turun
      let move = length * 2;

      // batas maksimal turun
      if(move > 350){
        move = 350;
      }

      // pindahkan box
      box.style.top = start + move + "px";

      // ganti emoji berdasarkan beban
      const emoji = document.querySelector(".emoji");

      if(length == 0){
        emoji.textContent = "😊";
      }
      else if(length < 30){
        emoji.textContent = "😐";
      }
      else if(length < 80){
        emoji.textContent = "😟";
      }
      else{
        emoji.textContent = "😵‍💫";
      }

    });
  </script>

</body>
</html>
